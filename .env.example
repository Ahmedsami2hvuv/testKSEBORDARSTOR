# نسخ هذا الملف إلى .env محلياً واملأ القيم. في Railway تُضاف المتغيرات من لوحة المشروع.

# PostgreSQL (من Railway: Postgres → Connect → DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# عنوان الموقع العلني (للروابط في تيليجرام وواتساب وصفحة المندوب /mandoub)
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# Web Push — إشعارات حقيقية في شريط الهاتف حتى عند إغلاق المتصفح (VAPID)
# أنشئ مفاتيحاً: npx web-push generate-vapid-keys
# VAPID_SUBJECT يُفضّل mailto:بريدك@النطاق
# VAPID_PUBLIC_KEY نفس القيمة في NEXT_PUBLIC_VAPID_PUBLIC_KEY للعميل (اختياري إن لم تُعرَّض عبر API)
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:you@example.com"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# اختياري — مجلد دائم لصور الطلبات والصوت (مهم على Railway: أضف Volume ووجّهه لنفس المسار)
# مثال: UPLOAD_DIR="/data/uploads" ثم في Railway: Volume mount path = /data/uploads
# UPLOAD_DIR=""

# لوحة الإدارة — عيّن كلمة مرور قوية وسرّاً عشوائياً طويلاً (لا تشاركهما)
ADMIN_PASSWORD=""
# مفتاح توقيع جلسة الإدارة (مثلاً 32 حرفاً عشوائياً أو أكثر)
ADMIN_SESSION_SECRET=""

# بوت تيليجرام
TELEGRAM_BOT_TOKEN=""
# معرف المجموعة (يمكن الرقم كما يظهر من getUpdates أو الصيغة -100...)
TELEGRAM_GROUP_CHAT_ID=""
# اختياري — معرّف تيليجرام الرقمي للمدير (واحد) أو TELEGRAM_ADMIN_USER_IDS بعدة معرّفات مفصولة بفاصلة — لوحة الإدارة في الخاص: /start أو /admin
# TELEGRAM_ADMIN_USER_ID="123456789"
# TELEGRAM_ADMIN_USER_IDS="111,222"
# اختياري — سرّ التحقق من webhook (نفس القيمة في setWebhook كـ secret_token)
# POST https://api.telegram.org/bot<TOKEN>/setWebhook?url=<https://your-app/api/telegram/webhook>&secret_token=<نفس_القيمة>
# إن وُضع هنا يجب أن يطابق secret_token في setWebhook وإلا لن تصل التحديثات (الأزرار لا تستجيب).
TELEGRAM_WEBHOOK_SECRET=""
# اختياري — لعرض اليوزر في رسائل الاختبار فقط
TELEGRAM_BOT_USERNAME=""

# كود الدولة لتطبيع أرقام واتساب (افتراضي العراق 964)
NEXT_PUBLIC_WHATSAPP_DEFAULT_CC="964"
# اختياري — توقيع روابط المندوب. يُفضّل تعيينه بقيمة ثابتة طويلة حتى لا تنكسر الروابط عند تغيير جلسة الإدارة
# إن لم تُضف يُستخدم ADMIN_SESSION_SECRET (يجب أن يكون 16 حرفاً فأكثر)
DELEGATE_PORTAL_SECRET=""
# اختياري — توقيع رابط إدخال الطلب للعميل /client/order (موظف المحل). إن لم تُضف يُستخدم SHOP_PORTAL ثم DELEGATE_PORTAL ثم ADMIN_SESSION_SECRET
# EMPLOYEE_ORDER_PORTAL_SECRET=""
# SHOP_PORTAL_SECRET=""
# اختياري — مدة صلاحية رابط موظف المحل /client/order بالأيام (افتراضي 90). روابط المندوب /mandoub دائمة.
# DELEGATE_PORTAL_LINK_TTL_DAYS="90"
# اختياري — قالب «إرسال الرابط»: {shop} {link} {portal} {employee} و \n للأسطر
# NEXT_PUBLIC_WHATSAPP_SHARE_TEMPLATE="السلام عليكم\nصفحة الطلبات:\n{portal}\nالمحل: {shop}\n{link}"
# اختياري — سطر تحية «فتح الرابط مباشرة»: {employee}
# NEXT_PUBLIC_WHATSAPP_DIRECT_GREETING="مرحباً، معك {employee}"
